# Copy this file to .env and fill in your key.
# Get one at: https://aistudio.google.com/apikey

GEMINI_API_KEY=

# Optional — override the default model. "NanoBanana 2" maps to the Gemini 2.5
# Flash Image family. Use "gemini-3-pro-image" (or whatever is current) for
# the higher-quality tier.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Port for the local server
PORT=4173
